# ADMS TCP Server Configuration Template
# Rename this file to '.env' and place it in the same directory as the executable.

# TCP Port to listen for ADMS connections (default is 4370)
ADMS_PORT=4370

# Logging Level: debug, info, warn, error
LOG_LEVEL=info

# File path for logs
FAILED_EVENTS_LOG=./logs/failed-events.jsonl
APP_LOG=./logs/app.log
ATTENDANCE_LOG=./logs/attendance.jsonl

# Cloud API settings (optional: uncomment to enable cloud forwarding)
# CLOUD_API_URL=https://api.example.com/events
# CLOUD_API_AUTH_HEADER=Authorization
# CLOUD_API_AUTH_VALUE=Bearer your_secret_token
# CLOUD_API_TIMEOUT=10000
